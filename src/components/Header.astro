---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
import siamentisLogo from "../assets/siamentis_logo.svg";

const { translationUrl } = Astro.props;
const allPages = import.meta.glob("../pages/**/*.{md,mdx,astro}");
const { pathname } = Astro.url;
const isThai = pathname.startsWith("/th");
const currentLang = isThai ? "th" : "en";

// 3. คำนวณ URL แบบอัตโนมัติ (สำหรับหน้า Static)
let autoTargetUrl = "";
if (isThai) {
  autoTargetUrl = pathname.replace(/^\/th/, "/en");
} else {
  if (pathname.startsWith("/en")) {
    autoTargetUrl = pathname.replace(/^\/en/, "/th");
  } else {
    autoTargetUrl = "/th" + pathname;
  }
}

// 4. ฟังก์ชันตรวจสอบว่ามีไฟล์สำหรับ URL นั้นจริงหรือไม่?
function checkTargetExists(url: string) {
  // ลบ trailing slash ออกก่อนเปรียบเทียบ (เช่น /th/about/ -> /th/about)
  const cleanUrl = url.replace(/\/$/, "");

  // วนลูปเช็คไฟล์ทั้งหมดที่เรา scan มา
  for (const path in allPages) {
    // แปลง path ของไฟล์ (เช่น ../pages/th/about.md) ให้เป็น URL (เช่น /th/about)
    let pageUrl = path
      .replace("../pages", "") // ลบ path ข้างหน้า
      .replace(/\.(astro|mdx|md)$/, "") // ลบนามสกุลไฟล์
      .replace(/\/index$/, ""); // ถ้าเป็น index ให้ลบออก (เช่น /th/index -> /th)

    // ถ้า pageUrl ว่างเปล่า แสดงว่าเป็นหน้า root (/)
    if (pageUrl === "") pageUrl = "/";

    // เปรียบเทียบ
    if (pageUrl === cleanUrl) {
      return true; // เจอคู่!
    }
  }
  return false; // ไม่เจอ
}

// 5. 🔥 ไฮไลท์: Logic ตัดสินใจ (Hybrid)
let targetUrl = "";
let hasTranslation = false;

if (translationUrl) {
  targetUrl = translationUrl;
  hasTranslation = true; // ถ้าส่งมาแสดงว่ามีแน่นอน
} else {
  targetUrl = autoTargetUrl;
  hasTranslation = checkTargetExists(targetUrl);
}

// สร้างข้อมูลเมนูย่อย (จะได้แก้ที่เดียวแล้วเปลี่ยนทั้ง Mobile/Desktop)
const projectLinks = [
  {
    name: "Samsung Solve for Tomorrow",
    href: `/${currentLang}/samsung-solve-for-tomorrow`,
  },
  {
    name: "Samsung Smart Learning Center",
    href: `/${currentLang}/samsung-smart-learning-center`,
  },
  {
    name: "Samsung Career Discovery",
    href: `/${currentLang}/samsung-career-discovery`,
  },
  {
    name: "Samsung Future Career Bootcamp",
    href: `/${currentLang}/samsung-future-career-bootcamp`,
  },
  {
    name: "Bridgestone B-Active",
    href: `/${currentLang}/bridgestone-b-active`,
  },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="container max-w-6xl mx-auto px-6 py-3">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center">
        <img
          src={siamentisLogo.src}
          alt={SITE_TITLE}
          class="h-auto w-[150px] object-contain !rounded-none"
        />
      </a>
      <button
        id="menu-btn"
        class="block md:hidden text-gray-700 focus:outline-none p-2"
        aria-label="Toggle Menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div id="menu-items" class="hidden md:flex items-center space-x-6">
        <div class="relative group">
          <button
            class="flex items-center font-medium text-gray-700 hover:text-orange-500 transition-colors py-2"
          >
            Past Projects
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 ml-1 transition-transform group-hover:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div
            class="absolute left-0 top-full pt-2 w-64 hidden group-hover:block hover:block z-50"
          >
            <div
              class="bg-white rounded-lg shadow-xl border border-gray-100 overflow-hidden py-1"
            >
              {
                projectLinks.map((project) => (
                  <a
                    href={project.href}
                    class="block px-4 py-3 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 transition-colors"
                  >
                    {project.name}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
        <HeaderLink href={`/${currentLang}/services`}>Services</HeaderLink>
        <HeaderLink href={`/${currentLang}/blog`}>Blog</HeaderLink>
        <HeaderLink href={`/${currentLang}/about`}>About</HeaderLink>
        {
          hasTranslation && (
            <a
              href={targetUrl}
              class="language-switcher inline-flex items-center px-3 py-1  hover:bg-gray-100 transition-colors ml-4"
              title={isThai ? "Switch to English" : "สลับเป็นภาษาไทย"}
            >
              <span class="mr-1">{isThai ? "🇺🇸" : "🇹🇭"}</span>
              <span class="text-sm font-semibold">{isThai ? "EN" : "TH"}</span>
            </a>
          )
        }
      </div>
    </div>

    <div
      id="mobile-menu"
      class="hidden md:hidden mt-4 pb-4 border-t border-gray-100"
    >
      <div class="flex flex-col space-y-4 pt-4 text-center">
        <HeaderLink href={`/${currentLang}/blog`}>Blog</HeaderLink>
        <HeaderLink href={`/${currentLang}/about`}>About</HeaderLink>

        <div class="flex flex-col items-center w-full">
          <button
            id="mobile-submenu-btn"
            class="flex items-center font-medium text-gray-700 py-2"
          >
            Past Projects
            <svg
              id="mobile-arrow"
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 ml-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div
            id="mobile-submenu-list"
            class="hidden flex-col items-center w-full bg-gray-50 mt-2 py-2 space-y-2 rounded-lg"
          >
            {
              projectLinks.map((project) => (
                <a
                  href={project.href}
                  class="block w-full py-2 text-sm text-gray-600 hover:text-orange-600"
                >
                  {project.name}
                </a>
              ))
            }
          </div>
        </div>
        {
          hasTranslation && (
            <div class="flex justify-center">
              <a
                href={targetUrl}
                class="language-switcher inline-flex items-center px-3 py-1 rounded-full hover:bg-gray-100 transition-colors"
                title={isThai ? "Switch to English" : "สลับเป็นภาษาไทย"}
              >
                <span class="mr-1">{isThai ? "🇺🇸" : "🇹🇭"}</span>
                <span class="text-sm font-semibold">
                  {isThai ? "EN" : "TH"}
                </span>
              </a>
            </div>
          )
        }
      </div>
    </div>
  </nav>
</header>

<script>
  // Script สำหรับ Toggle เมนู
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      // สลับ class 'hidden'
      // ถ้ามี hidden อยู่ -> เอาออก (แสดงเมนู)
      // ถ้าไม่มี hidden -> ใส่เข้าไป (ซ่อนเมนู)
      mobileMenu.classList.toggle("hidden");
    });
  }

  // Script ใหม่ (Toggle Mobile Submenu)
  const subMenuBtn = document.getElementById("mobile-submenu-btn");
  const subMenuList = document.getElementById("mobile-submenu-list");
  const mobileArrow = document.getElementById("mobile-arrow");

  if (subMenuBtn && subMenuList && mobileArrow) {
    subMenuBtn.addEventListener("click", () => {
      // 1. สลับแสดง/ซ่อน รายการ
      subMenuList.classList.toggle("hidden");
      subMenuList.classList.toggle("flex");

      // 2. หมุนลูกศร
      mobileArrow.classList.toggle("rotate-180");
    });
  }
</script>
