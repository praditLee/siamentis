---
import { getCollection } from "astro:content";
import { Image } from "astro:assets"; // 👈 (1) Import <Image> สำหรับ heroImage

// (2) ❗️ ตรวจสอบ Path เหล่านี้ ❗️
// ให้แน่ใจว่ามันชี้ไปที่ไฟล์ Layout/Component ของคุณถูกต้อง
import BaseLayout from "../../../layouts/BlogPost.astro";
import FormattedDate from "../../../components/FormattedDate.astro";

// (3) สร้าง 2 หน้า: /en/blog และ /th/blog
export async function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "th" } }];
}

const { lang } = Astro.params;

// (4) ดึงโพสต์ทั้งหมด กรองตามภาษา และเรียงตามวันที่
const allPosts = await getCollection("blog");
const postsInThisLang = allPosts
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()); // (ใช้ 'date' ที่เราแก้)

// (5) ตั้งชื่อหน้าตามภาษา
const pageTitle = lang === "en" ? "Blog" : "บทความ";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="py-12">
    <div class="container mx-auto max-w-screen-xl px-6">
      <h1 class="mb-12 text-center text-4xl font-bold md:text-5xl">
        {pageTitle}
      </h1>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          postsInThisLang.map((post) => {
            // (8) ดึง Slug ที่ถูกต้อง (ส่วนท้ายสุด)
            const slug = post.slug.split("/").pop();
            const href = `/${lang}/blog/${slug}/`;

            return (
              <article class="flex flex-col overflow-hidden rounded-lg shadow-lg transition-transform duration-300 hover:scale-[1.03]">
                <a href={href}>
                  {post.data.heroImage ? (
                    // (A) ถ้ามี heroImage
                    <Image
                      src={post.data.heroImage}
                      alt={`Hero image for ${post.data.title}`}
                      width={600}
                      height={340}
                      format="webp"
                      class="h-56 w-full object-cover"
                    />
                  ) : (
                    // (B) ถ้าไม่มี (แสดง Placeholder สีเทา)
                    <div class="h-56 w-full bg-gray-200" />
                  )}
                </a>

                <div class="flex flex-1 flex-col justify-between bg-white p-6">
                  <div>
                    <h2 class="mb-3 text-2xl font-bold leading-tight">
                      <a href={href} class="hover:text-blue-600">
                        {post.data.title}
                      </a>
                    </h2>

                    <p class="mb-4 text-sm text-gray-500">
                      <FormattedDate date={post.data.date} />
                    </p>

                    {post.data.description && (
                      <p class="mb-4 text-gray-700">{post.data.description}</p>
                    )}
                  </div>

                  <a
                    href={href}
                    class="mt-4 font-semibold text-blue-600 hover:underline"
                  >
                    {lang === "en" ? "Read more" : "อ่านต่อ"} &rarr;
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
