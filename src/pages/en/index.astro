  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <HeroSlider slides={mySlides} />

    <section class="container max-w-6xl mx-auto px-6 py-12 md:py-20">
      <h1 class="text-4xl font-bold mb-12 text-center font-heading">
        Our Past Projects
      </h1>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12"
      >
        {
          projects.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              images={project.images}
              link={project.link}
            />
          ))
        }
      </div>
    </section>
    <Footer />
    <script>
      import Swiper from "swiper";
      import { Navigation, Pagination } from "swiper/modules";

      document.addEventListener("DOMContentLoaded", () => {
        // 1. หา Card ทั้งหมดที่มี class .project-swiper
        const allSliders = document.querySelectorAll(".project-swiper");

        // 2. วนลูปสร้าง Swiper ให้แต่ละการ์ด
        allSliders.forEach((sliderElement) => {
          new Swiper(sliderElement as HTMLElement, {
            modules: [Navigation, Pagination],
            loop: true,
            slidesPerView: 1,
            spaceBetween: 0,

            // ตั้งค่าปุ่ม Navigation (ต้องหาจากใน sliderElement นั้นๆ เท่านั้น)
            navigation: {
              nextEl: sliderElement.querySelector(
                ".swiper-button-next"
              ) as HTMLElement,
              prevEl: sliderElement.querySelector(
                ".swiper-button-prev"
              ) as HTMLElement,
            },

            // ตั้งค่า Pagination
            pagination: {
              el: sliderElement.querySelector(
                ".swiper-pagination"
              ) as HTMLElement,
              clickable: true,
              dynamicBullets: true, // ทำให้จุดขนาดไม่เท่ากัน (ดูทันสมัย)
            },
          });
        });
      });
    </script>
  </body>
</html>
