{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true
  },
  "baseUrl": ".", // 👈 (สำคัญ) บอกว่า "Root" ของโปรเจกต์อยู่ที่นี่
    "paths": {
      "~/*": ["src/*"] // 👈 (สำคัญ) บอกว่า "~/" หมายถึง "src/"
    }
}
